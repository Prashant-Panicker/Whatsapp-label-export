{
  "manifest_version": 3,
  "name": "WhatsApp Label Contact Exporter",
  "description": "Export contacts from the currently opened WhatsApp Web label view to CSV or JSON.",
  "version": "0.3.0",
  "permissions": [
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "action": {
    "default_title": "Label Exporter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["injected.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
